// Multi-tenant agent state.
//
// Primary key everywhere is the user's EOA wallet address — under
// EIP-7702 / Calibur-style delegation the EOA *is* the account, so the
// same string identifies the user across chains. The DB column is
// historically named `safe_address` (kept via @map for zero-migration
// compatibility); the application-level field is `walletAddress`.
// Per-chain runtime state goes in AgentState.state JSON when needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AgentRole {
  pm
  alm
  router
  executor
}

enum IntentStatus {
  pending
  netted
  routed
  executing
  executed
  failed
  expired
}

model User {
  walletAddress String   @id @map("safe_address")
  ownerEoa      String   @map("owner_eoa")
  /// Comma-separated list of chains where the wallet is active.
  chains        String   @default("")
  /// User-tunable risk profile. PM reads this every tick to pick its
  /// system prompt + tolerance + cadence. One of:
  /// 'conservative' | 'balanced' | 'aggressive' | 'degen'.
  riskProfile   String   @default("balanced") @map("risk_profile")
  /// Optional per-knob overrides on top of the profile preset. Any key
  /// from ProfileConfig can be customized: stableFloor, maxToken,
  /// maxShiftPerTick, toleranceBps, cadenceMinutes. PM merges this on
  /// top of the profile defaults each tick.
  customConfig  Json?    @map("custom_config")
  createdAt     DateTime @default(now()) @map("created_at")

  sessions    Session[]
  intents     Intent[]
  events      Event[]
  agentStates AgentState[]

  @@map("users")
}

model Session {
  id             String    @id @default(uuid())
  walletAddress  String    @map("safe_address")
  agent          AgentRole
  /// Public address of THIS agent's service keypair, mirrored from
  /// the onchain delegation grant. Same value across all users for
  /// a given agent — see Model B in agents/README.md.
  sessionAddress String    @map("session_address")
  /// Stable hash of the policy granted onchain — for change detection.
  policyHash     String    @map("policy_hash")
  grantedAt      DateTime  @default(now()) @map("granted_at")
  validUntil     DateTime  @map("valid_until")

  user           User      @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)

  @@unique([walletAddress, agent], map: "sessions_safe_address_agent_key")
  @@index([agent, validUntil])
  @@map("sessions")
}

model Intent {
  id            String       @id @default(uuid())
  walletAddress String       @map("safe_address")
  fromAgent     AgentRole    @map("from_agent")
  /// Free-form per-intent payload. Schema enforced in TS, not SQL.
  payload       Json
  status        IntentStatus @default(pending)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  user          User         @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)

  @@index([walletAddress, status], map: "intents_safe_address_status_idx")
  @@index([status, createdAt])
  @@map("intents")
}

model Event {
  id            String     @id @default(uuid())
  walletAddress String     @map("safe_address")
  agent         AgentRole?
  /// Short event kind tag, e.g. "session.granted", "intent.executed", "alm.tick".
  kind          String
  payload       Json?
  createdAt     DateTime   @default(now()) @map("created_at")

  user          User       @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)

  @@index([walletAddress, createdAt], map: "events_safe_address_created_at_idx")
  @@index([kind, createdAt])
  @@map("events")
}

model AgentState {
  agent         AgentRole
  walletAddress String    @map("safe_address")
  /// Per-tenant runtime state — last-tick timestamp, cached LP positions,
  /// allocation snapshot, whatever each agent needs.
  state         Json
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User      @relation(fields: [walletAddress], references: [walletAddress], onDelete: Cascade)

  @@id([agent, walletAddress])
  @@map("agent_state")
}
