# --- Database (Supabase Postgres) ----------------------------------------
# DATABASE_URL  — pooler URL (port 6543) used by the Prisma client at runtime
# DIRECT_URL    — direct URL (port 5432) used by Prisma migrations
DATABASE_URL=postgresql://postgres:PASSWORD@aws-0-XXX.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres:PASSWORD@db.XXX.supabase.co:5432/postgres

# --- AXL (Gensyn Agent eXchange Layer) ------------------------------------
# AXL runs as a binary on each agent host. Each agent talks to its own
# localhost AXL daemon. Default port is 9000 — override per agent if you
# run multiple agents on the same machine.
AXL_PM_ENDPOINT=http://localhost:9001
AXL_ALM_ENDPOINT=http://localhost:9002
AXL_ROUTER_ENDPOINT=http://localhost:9003
AXL_EXECUTOR_ENDPOINT=http://localhost:9004

# --- Agent service keys (Model B) ---------------------------------------
# Each agent has ONE fixed keypair. All users grant their Safe's Smart
# Sessions policy to these addresses. Compromise blast radius is bounded
# by per-user policy caps enforced onchain.
#
# Generate fresh keys once with: openssl rand -hex 32  (or `cast wallet new`)
# After setting these, derive the addresses (each agent logs them at boot)
# and paste them into src/config/swarm.ts in the extension.
PM_SERVICE_PRIVKEY=
ALM_SERVICE_PRIVKEY=
ROUTER_SERVICE_PRIVKEY=
EXECUTOR_SERVICE_PRIVKEY=

# --- Onchain reads --------------------------------------------------------
# Public RPCs are fine for read-only event subscriptions. For high-volume
# reads (ALM tick), point at Alchemy / Infura with your own API key.
RPC_MAINNET=https://eth.llamarpc.com
RPC_BASE=https://base.llamarpc.com
RPC_UNICHAIN=https://unichain.drpc.org

# --- KeeperHub (Executor only) -------------------------------------------
# https://app.keeperhub.com — generate API key, paste here.
KEEPERHUB_API_KEY=
KEEPERHUB_BASE_URL=https://api.keeperhub.com

# Demo helper: when true, the Executor skips Uniswap + KeeperHub and
# writes a synthetic success receipt. Use this to demo the full PM →
# Router → Executor pipeline on chains where Uniswap Trading API isn't
# available (Sepolia, Unichain Sepolia).
EXECUTOR_MOCK=false

# KeeperHub MCP endpoint (override only if KH moves it).
KEEPERHUB_MCP_URL=https://app.keeperhub.com/mcp
# Optional: pin a known-good action id for the swap protocol action.
# When unset, executor calls `search_protocol_actions` once at startup
# and caches the result.
KEEPERHUB_SWAP_ACTION_ID=
# Address of the KH org-managed wallet. Passed to Uniswap as `swapper`
# so the route is built for that wallet's balances/permits.
KEEPERHUB_WALLET_ADDRESS=

# --- Uniswap Trading API (Executor + ALM) --------------------------------
# https://developers.uniswap.org — request access, paste API key.
UNISWAP_API_KEY=
UNISWAP_API_BASE=https://trade-api.gateway.uniswap.org/v1

# --- Pimlico (fallback bundler if KeeperHub is unavailable) --------------
PIMLICO_API_KEY=

# --- LLM provider (PM only) ----------------------------------------------
# Selects which model endpoint PM uses to decide allocations.
#   groq   — hosted Llama/Qwen/Mixtral via Groq (default)
#   hermes — Nous Research Hermes (Portal or self-hosted hermes-agent
#            OpenAI-compatible server). https://github.com/NousResearch/hermes-agent
LLM_PROVIDER=groq

# --- Groq (when LLM_PROVIDER=groq) ---------------------------------------
# Get key at https://console.groq.com (free tier, no card required).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Hermes / Nous Portal (when LLM_PROVIDER=hermes) ---------------------
# Default base URL targets Nous Portal (https://portal.nousresearch.com).
# Override HERMES_BASE_URL to point at a self-hosted hermes-agent server
# or any OpenAI-compatible endpoint.
HERMES_API_KEY=
HERMES_MODEL=Hermes-4-405B
HERMES_BASE_URL=https://inference-api.nousresearch.com/v1

# --- Zerion (PM reads portfolio context) ---------------------------------
# Same proxy URL the extension uses (proxy/zerion-worker.js).
ZERION_PROXY_URL=https://defi-swarm-zerion-proxy.chandrabosep.workers.dev

# --- Agents API (extension -> backend bridge) ----------------------------
# Port the agents/api Express server listens on. Extension reads
# VITE_AGENTS_API_URL (set in .env.local at the repo root) and POSTs
# session rows after each grantSession lands onchain.
API_PORT=8787
# Optional comma-separated origin allowlist for the CORS check.
# chrome-extension:// and moz-extension:// are always allowed.
API_ALLOWED_ORIGINS=http://localhost:5173
