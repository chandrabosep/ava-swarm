// Multi-tenant agent state.
//
// Primary key everywhere is the user's deterministic Safe address — it's
// the same string across chains so we don't have to scope by (chain, addr).
// Per-chain runtime state goes in AgentState.state JSON when needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AgentRole {
  pm
  alm
  router
  executor
}

enum IntentStatus {
  pending
  netted
  routed
  executing
  executed
  failed
  expired
}

model User {
  safeAddress String   @id @map("safe_address")
  ownerEoa    String   @map("owner_eoa")
  /// Comma-separated list of chains where the Safe is deployed + active.
  chains      String   @default("")
  /// User-tunable risk profile. PM reads this every tick to pick its
  /// system prompt + tolerance + cadence. One of:
  /// 'conservative' | 'balanced' | 'aggressive' | 'degen'.
  riskProfile String   @default("balanced") @map("risk_profile")
  /// Optional per-knob overrides on top of the profile preset. Any key
  /// from ProfileConfig can be customized: stableFloor, maxToken,
  /// maxShiftPerTick, toleranceBps, cadenceMinutes. PM merges this on
  /// top of the profile defaults each tick.
  customConfig Json?   @map("custom_config")
  createdAt   DateTime @default(now()) @map("created_at")

  sessions    Session[]
  intents     Intent[]
  events      Event[]
  agentStates AgentState[]

  @@map("users")
}

model Session {
  id             String    @id @default(uuid())
  safeAddress    String    @map("safe_address")
  agent          AgentRole
  /// Public address of THIS agent's service keypair, mirrored from
  /// the onchain Smart Sessions grant. Same value across all users for
  /// a given agent — see Model B in agents/README.md.
  sessionAddress String    @map("session_address")
  /// Stable hash of the policy granted onchain — for change detection.
  policyHash     String    @map("policy_hash")
  grantedAt      DateTime  @default(now()) @map("granted_at")
  validUntil     DateTime  @map("valid_until")

  user           User      @relation(fields: [safeAddress], references: [safeAddress], onDelete: Cascade)

  @@unique([safeAddress, agent])
  @@index([agent, validUntil])
  @@map("sessions")
}

model Intent {
  id          String       @id @default(uuid())
  safeAddress String       @map("safe_address")
  fromAgent   AgentRole    @map("from_agent")
  /// Free-form per-intent payload. Schema enforced in TS, not SQL.
  payload     Json
  status      IntentStatus @default(pending)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user        User         @relation(fields: [safeAddress], references: [safeAddress], onDelete: Cascade)

  @@index([safeAddress, status])
  @@index([status, createdAt])
  @@map("intents")
}

model Event {
  id          String     @id @default(uuid())
  safeAddress String     @map("safe_address")
  agent       AgentRole?
  /// Short event kind tag, e.g. "session.granted", "intent.executed", "alm.tick".
  kind        String
  payload     Json?
  createdAt   DateTime   @default(now()) @map("created_at")

  user        User       @relation(fields: [safeAddress], references: [safeAddress], onDelete: Cascade)

  @@index([safeAddress, createdAt])
  @@index([kind, createdAt])
  @@map("events")
}

/// Global swarm-wide settings. Single-row table keyed by id='global'.
/// Right now this only holds the Hermes overrides — paste an API key /
/// model / base URL / skill text from the extension UI and PM picks them
/// up on the next tick, no env var or restart required.
///
/// API keys are stored in plaintext — same trust level as agents/.env on
/// the server. Don't deploy this without rotating to a KMS-backed secret
/// store if you take real money.
model SwarmSettings {
  id            String   @id @default("global")
  hermesEnabled Boolean  @default(false) @map("hermes_enabled")
  hermesApiKey  String?  @map("hermes_api_key")
  hermesModel   String?  @map("hermes_model")
  hermesBaseUrl String?  @map("hermes_base_url")
  /// Optional free-form text appended to PM's system prompt when Hermes
  /// is active. Hermes Agent's actual `skills/*.py` won't run inside the
  /// swarm — this is the "what should the model also consider" slot.
  hermesSkill   String?  @map("hermes_skill")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("swarm_settings")
}

model AgentState {
  agent       AgentRole
  safeAddress String    @map("safe_address")
  /// Per-tenant runtime state — last-tick timestamp, cached LP positions,
  /// allocation snapshot, whatever each agent needs.
  state       Json
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User      @relation(fields: [safeAddress], references: [safeAddress], onDelete: Cascade)

  @@id([agent, safeAddress])
  @@map("agent_state")
}
