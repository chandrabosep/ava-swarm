# Reown AppKit (formerly WalletConnect Cloud) — get one at https://cloud.reown.com
VITE_REOWN_PROJECT_ID=

# Zerion proxy URL — Cloudflare Worker that forwards to api.zerion.io
# and adds CORS headers. Deploy proxy/zerion-worker.js, then paste the
# resulting *.workers.dev URL here. The API key lives on the Worker as a
# Cloudflare secret, NOT in the extension bundle.
#
# Example: https://defi-swarm-zerion-proxy.your-subdomain.workers.dev
VITE_ZERION_PROXY_URL=

# (Optional, legacy) Direct Zerion API key — only used if VITE_ZERION_PROXY_URL
# isn't set. Calling api.zerion.io directly from a browser extension hits CORS
# blocks; prefer the proxy path.
VITE_ZERION_API_KEY=

# Pimlico — ERC-4337 bundler we use to relay UserOps for the Safe smart
# account. Get a free dev key at https://dashboard.pimlico.io. The same key
# works across Unichain / Base / Mainnet via Pimlico's chain-aware RPC.
VITE_PIMLICO_API_KEY=
